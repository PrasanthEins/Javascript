console.log("Number Type Program")

function numbertype()
{
    let a = prompt("Enter a number: ")
    if (a>0)
    {
        console.log("It is a positive number")
    }
    else if (a<0)
    {
        console.log("It is a negative number")
    }
    else
    {
        console.log("It is a neutral number")
    }
}

numbertype()
